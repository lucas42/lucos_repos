<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Open Pull Requests</title>
	<link rel="icon" href="/icon" type="image/png">
	<style>
		body {
			font-family: system-ui, sans-serif;
			margin: 0;
			padding: 0;
			background: #f8f9fa;
			color: #212529;
		}
		main {
			padding: 1.5rem 2rem;
			overflow-x: auto;
		}
		h1 {
			margin-top: 0;
			margin-bottom: 0.5rem;
		}
		.nav-link {
			font-size: 0.9rem;
			margin-bottom: 1rem;
			display: block;
		}
		.nav-link a {
			color: #0d6efd;
		}
		.summary {
			display: flex;
			gap: 1.5rem;
			margin-bottom: 1.5rem;
			flex-wrap: wrap;
		}
		.stat-card {
			background: #fff;
			border: 1px solid #dee2e6;
			border-radius: 8px;
			padding: 1rem 1.5rem;
			min-width: 140px;
		}
		.stat-card .label {
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			color: #6c757d;
			margin-bottom: 0.25rem;
		}
		.stat-card .value {
			font-size: 1.75rem;
			font-weight: 700;
			line-height: 1;
		}
		.stat-card .value.timestamp {
			font-size: 0.95rem;
			font-weight: 400;
		}
		.stat-card.neutral .value { color: #0d6efd; }
		table {
			border-collapse: collapse;
			background: #fff;
			border: 1px solid #dee2e6;
			border-radius: 8px;
			overflow: hidden;
			min-width: 100%;
		}
		th, td {
			border: 1px solid #dee2e6;
			padding: 0.5rem 0.75rem;
			text-align: center;
			white-space: nowrap;
		}
		th:first-child, td:first-child {
			text-align: left;
		}
		thead th {
			background: #343a40;
			color: #fff;
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 0.04em;
		}
		tbody tr:nth-child(even) {
			background: #f8f9fa;
		}
		tbody tr:hover {
			background: #e9ecef;
		}
		.repo-name {
			font-family: monospace;
			font-size: 0.85rem;
		}
		.count-zero {
			color: #adb5bd;
		}
		.count-nonzero {
			font-weight: 600;
		}
		.count-fail {
			color: #dc3545;
			font-weight: 700;
		}
		.count-pending {
			color: #fd7e14;
			font-weight: 600;
		}
		.count-approved {
			color: #198754;
			font-weight: 600;
		}
		td a {
			color: inherit;
			text-decoration: none;
		}
		td a:hover {
			text-decoration: underline;
		}
	</style>
</head>
<body>
	<lucos-navbar>Open PRs</lucos-navbar>
	<main>
		<div class="nav-link"><a href="/">&larr; Compliance Dashboard</a></div>

		<div class="summary">
			<div class="stat-card neutral">
				<div class="label">Last Fetched</div>
				{{if .LastFetchAt.IsZero}}
				<div class="value timestamp">Never</div>
				{{else}}
				<div class="value timestamp" title="{{.LastFetchAt.UTC.Format "2006-01-02T15:04:05Z"}}">{{.LastFetchAt.UTC.Format "2 Jan 2006 15:04 UTC"}}</div>
				{{end}}
			</div>
		</div>

		{{if eq (len .Repos) 0}}
		<p>No repos with open pull requests{{if .LastFetchAt.IsZero}} — waiting for first sweep to complete{{end}}.</p>
		{{else}}
		<table>
			<thead>
				<tr>
					<th>Repository</th>
					<th title="PRs with at least one failing check">Failing</th>
					<th title="PRs with pending checks (no failures)">Pending</th>
					<th title="PRs with all checks passing, no reviews">No Reviews</th>
					<th title="PRs with changes requested">Changes Req.</th>
					<th title="PRs approved by code-reviewer[bot] but not lucas42">Bot Only</th>
					<th title="PRs approved by both code-reviewer[bot] and lucas42">Fully Approved</th>
					<th>Total</th>
				</tr>
			</thead>
			<tbody>
				{{range .Repos}}
				<tr>
					<td class="repo-name"><a href="https://github.com/{{.RepoName}}/pulls">{{.RepoName}}</a></td>
					<td class="{{if gt .FailingChecks 0}}count-fail{{else}}count-zero{{end}}">
						{{if gt .FailingChecks 0}}<a href="https://github.com/{{.RepoName}}/pulls?q=is%3Apr+is%3Aopen+status%3Afailure">{{.FailingChecks}}</a>{{else}}0{{end}}
					</td>
					<td class="{{if gt .PendingChecks 0}}count-pending{{else}}count-zero{{end}}">
						{{if gt .PendingChecks 0}}<a href="https://github.com/{{.RepoName}}/pulls?q=is%3Apr+is%3Aopen+status%3Apending">{{.PendingChecks}}</a>{{else}}0{{end}}
					</td>
					<td class="{{if gt .NoReviews 0}}count-nonzero{{else}}count-zero{{end}}">
						{{if gt .NoReviews 0}}<a href="https://github.com/{{.RepoName}}/pulls?q=is%3Apr+is%3Aopen+review%3Anone+status%3Asuccess">{{.NoReviews}}</a>{{else}}0{{end}}
					</td>
					<td class="{{if gt .ChangesRequested 0}}count-fail{{else}}count-zero{{end}}">
						{{if gt .ChangesRequested 0}}<a href="https://github.com/{{.RepoName}}/pulls?q=is%3Apr+is%3Aopen+review%3Achanges_requested">{{.ChangesRequested}}</a>{{else}}0{{end}}
					</td>
					<td class="{{if gt .BotApprovedOnly 0}}count-nonzero{{else}}count-zero{{end}}">
						{{if gt .BotApprovedOnly 0}}<a href="https://github.com/{{.RepoName}}/pulls?q=is%3Apr+is%3Aopen+review%3Aapproved+-reviewed-by%3Alucas42">{{.BotApprovedOnly}}</a>{{else}}0{{end}}
					</td>
					<td class="{{if gt .FullyApproved 0}}count-approved{{else}}count-zero{{end}}">
						{{if gt .FullyApproved 0}}<a href="https://github.com/{{.RepoName}}/pulls?q=is%3Apr+is%3Aopen+review%3Aapproved+reviewed-by%3Alucas42">{{.FullyApproved}}</a>{{else}}0{{end}}
					</td>
					<td class="count-nonzero"><a href="https://github.com/{{.RepoName}}/pulls">{{.Total}}</a></td>
				</tr>
				{{end}}
			</tbody>
		</table>
		{{end}}
	</main>
	<script src="/lucos_navbar.js" type="text/javascript"></script>
</body>
</html>
